{
  "version": "6.9.3-nightly",
  "description": "Chatterino 7TV nightly - Twitch chat client with 7TV emote and cosmetic support (formerly Chatterino7).",
  "homepage": "https://github.com/SevenTV/chatterino7",
  "license": "MIT",
  "url": "https://github.com/SevenTV/chatterino7/releases/download/nightly-build/chatterino-windows-x86-64-Qt-6.9.3.zip",
  "hash": { "type": "skip" },
  "extract_dir": "Chatterino2",
  "shortcuts": [["chatterino.exe", "Chatterino 7TV"]],
  "checkver": {
    "script": [
      "$r = Invoke-RestMethod 'https://api.github.com/repos/SevenTV/chatterino7/releases/tags/nightly-build'",
      "$a = $r.assets | Where-Object { $_.name -match 'chatterino-windows-x86-64-Qt-([\\d.]+)\\.zip' } | Select-Object -First 1",
      "if ($a.name -match 'Qt-([\\d.]+)\\.zip') { $qt = $Matches[1] } else { $qt = 'unknown' }",
      "$date = ([datetime]$a.updated_at).ToString('yyyyMMddHHmm')",
      "\"$qt-$date\""
    ],
    "regex": "(?<qt>[\\d.]+)-(?<date>\\d+)"
  },
  "autoupdate": {
    "url": "https://github.com/SevenTV/chatterino7/releases/download/nightly-build/chatterino-windows-x86-64-Qt-$matchQt.zip",
    "hash": { "type": "skip" }
  }
}
